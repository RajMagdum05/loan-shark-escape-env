# Loan Shark Escape Environment Configuration

# Base URL for the Loan Shark Escape FastAPI server (use your Hugging Face Space URL when grading remotely)
API_BASE_URL=http://localhost:7860

# Inference runs each task and calls /evaluate (comma-separated)
# TASK_IDS=lse-easy,lse-medium,lse-hard

# LLM configuration for inference
MODEL_NAME=gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Hugging Face Space configuration (optional)
HF_TOKEN=your_huggingface_token_here
LOCAL_IMAGE_NAME=loan-shark-escape-env
