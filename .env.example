# Loan Shark Escape — hackathon-style configuration
# (see https://www.scaler.com/school-of-technology/meta-pytorch-hackathon/dashboard )

# --- LLM (OpenAI-compatible client) ---
# API_BASE_URL is the *LLM* endpoint (not the environment server).
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=openai/gpt-oss-120b:novita
HF_TOKEN=

# Optional: use api.openai.com instead of HF router
# OPENAI_API_KEY=

# --- Environment server (FastAPI / Space) ---
ENV_BASE_URL=http://127.0.0.1:7860

# Comma-separated task IDs matching openenv.yaml
TASK_IDS=lse-easy,lse-medium,lse-hard

# Set true to run without any API key (rule-based policy)
USE_MOCK_AGENT=false
