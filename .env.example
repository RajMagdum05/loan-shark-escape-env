# Loan Shark Escape Environment Configuration
# Standard environment variables for the Meta PyTorch / OpenEnv Hackathon.

# Base URL for the Loan Shark Escape FastAPI server.
# Locally, this is http://localhost:7860.
# On Hugging Face, use your Space URL (e.g. https://user-space.hf.space).
API_BASE_URL=http://localhost:7860

# Model to use for inference. Suggest: gpt-4o-mini or gemini-1.5-flash.
MODEL_NAME=gemini-1.5-flash

# Required only if using OpenAI models.
OPENAI_API_KEY=

# Required only if using Google Gemini models.
GOOGLE_API_KEY=

# Your Hugging Face Access Token (used for remote evaluation/client access).
HF_TOKEN=

# Evaluation Configuration: Inference loops these task IDs and calls /evaluate per task.
TASK_IDS=lse-easy,lse-medium,lse-hard

# Internal Docker tagging configuration.
LOCAL_IMAGE_NAME=loan-shark-escape-env
